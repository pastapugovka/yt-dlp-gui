<Window
    x:Class="YtDlpGui.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:YtDlpGui"
    xmlns:views="using:YtDlpGui.Views"
    Title="YtDlp GUI"
    MinWidth="900"
    MinHeight="600"
    Width="1200"
    Height="750">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <InfoBar x:Name="GlobalInfoBar"
                 Grid.Row="0"
                 IsOpen="False"
                 IsClosable="True"
                 Severity="Informational"
                 HorizontalAlignment="Stretch" />

        <NavigationView x:Name="NavView"
                        Grid.Row="1"
                        IsSettingsVisible="True"
                        IsBackButtonVisible="Collapsed"
                        IsTitleBarAutoPaddingEnabled="False"
                        MenuItemsSource="{x:Bind NavMenuItems}"
                        SelectionChanged="NavView_SelectionChanged"
                        Loaded="NavView_Loaded"
                        OpenPaneLength="240">

            <NavigationView.PaneFooter>
                <StackPanel Orientation="Vertical" Padding="8">
                    <TextBlock Text="YtDlp GUI v1.0"
                               Opacity="0.6"
                               FontSize="11"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </NavigationView.PaneFooter>

            <NavigationView.HeaderTemplate>
                <DataTemplate>
                    <Grid Height="48">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding}"
                                   VerticalAlignment="Center"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="16,0,0,0" />
                    </Grid>
                </DataTemplate>
            </NavigationView.HeaderTemplate>

            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>
