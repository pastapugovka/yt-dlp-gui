<Page
    x:Class="YtDlpGui.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:YtDlpGui.Views"
    xmlns:vm="using:YtDlpGui.ViewModels">

    <ScrollViewer Padding="16" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20" MaxWidth="800" HorizontalAlignment="Center">

            <TextBlock Text="Настройки" Style="{StaticResource TitleTextBlockStyle}"/>

            <!-- Paths -->
            <Expander IsExpanded="True">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#x1F4C1;" FontSize="16"/>
                        <TextBlock Text="Пути к программам" Style="{StaticResource BodyTextBlockStyle}" FontWeight="SemiBold"/>
                    </StackPanel>
                </Expander.Header>
                <StackPanel Spacing="12" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="yt-dlp:" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{x:Bind ViewModel.YtDlpPath, Mode=TwoWay}" CornerRadius="4" Margin="0,0,8,0"/>
                        <Button Grid.Column="2" Content="..." Command="{x:Bind ViewModel.BrowseYtDlpCommand}" CornerRadius="4" Padding="12,8"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="ffmpeg:" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{x:Bind ViewModel.FfmpegPath, Mode=TwoWay}" CornerRadius="4" Margin="0,0,8,0"/>
                        <Button Grid.Column="2" Content="..." Command="{x:Bind ViewModel.BrowseFfmpegCommand}" CornerRadius="4" Padding="12,8"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Папка:" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{x:Bind ViewModel.OutputDir, Mode=TwoWay}" CornerRadius="4" Margin="0,0,8,0"/>
                        <Button Grid.Column="2" Content="..." Command="{x:Bind ViewModel.BrowseOutputDirCommand}" CornerRadius="4" Padding="12,8"/>
                    </Grid>
                </StackPanel>
            </Expander>

            <!-- Proxy & Network -->
            <Expander>
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#x1F310;" FontSize="16"/>
                        <TextBlock Text="Сеть и прокси" Style="{StaticResource BodyTextBlockStyle}" FontWeight="SemiBold"/>
                    </StackPanel>
                </Expander.Header>
                <StackPanel Spacing="12" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Прокси:" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{x:Bind ViewModel.ProxyUrl, Mode=TwoWay}" CornerRadius="4"
                                 PlaceholderText="socks5://127.0.0.1:1080"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="User-Agent:" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{x:Bind ViewModel.UserAgent, Mode=TwoWay}" CornerRadius="4"
                                 PlaceholderText="Mozilla/5.0 ..."/>
                    </Grid>
                </StackPanel>
            </Expander>

            <!-- Cookies -->
            <Expander>
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#x1F36A;" FontSize="16"/>
                        <TextBlock Text="Куки" Style="{StaticResource BodyTextBlockStyle}" FontWeight="SemiBold"/>
                    </StackPanel>
                </Expander.Header>
                <StackPanel Spacing="12" Padding="16">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Импорт из файла" Command="{x:Bind ViewModel.ImportCookiesCommand}" CornerRadius="4" Padding="12,8"/>
                        <Button Content="Импорт из браузера" Command="{x:Bind ViewModel.ImportCookiesFromBrowserCommand}" CornerRadius="4" Padding="12,8"/>
                        <Button Content="Очистить куки" Command="{x:Bind ViewModel.ClearCookiesCommand}" CornerRadius="4" Padding="12,8"/>
                    </StackPanel>
                    <TextBlock Text="Используйте кнопку 'Куки из буфера' на главном экране для быстрой вставки"
                               Opacity="0.6" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </Expander>

            <!-- Download Settings -->
            <Expander>
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#x2B07;" FontSize="16"/>
                        <TextBlock Text="Загрузка" Style="{StaticResource BodyTextBlockStyle}" FontWeight="SemiBold"/>
                    </StackPanel>
                </Expander.Header>
                <StackPanel Spacing="12" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Шаблон имени файла:" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{x:Bind ViewModel.FileNameTemplate, Mode=TwoWay}" CornerRadius="4"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Макс. загрузок:" VerticalAlignment="Center"/>
                        <NumberBox Grid.Column="1" Value="{x:Bind ViewModel.MaxConcurrentDownloads, Mode=TwoWay}"
                                   Minimum="1" Maximum="10" CornerRadius="4"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <CheckBox Content="Встраивать миниатюру" IsChecked="{x:Bind ViewModel.EmbedThumbnail, Mode=TwoWay}"/>
                        <CheckBox Content="Записывать метаданные" IsChecked="{x:Bind ViewModel.WriteMetadata, Mode=TwoWay}"/>
                        <CheckBox Content="Встраивать субтитры" IsChecked="{x:Bind ViewModel.EmbedSubtitles, Mode=TwoWay}"/>
                    </StackPanel>
                </StackPanel>
            </Expander>

            <!-- Appearance -->
            <Expander>
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#x1F3A8;" FontSize="16"/>
                        <TextBlock Text="Внешний вид" Style="{StaticResource BodyTextBlockStyle}" FontWeight="SemiBold"/>
                    </StackPanel>
                </Expander.Header>
                <StackPanel Spacing="12" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Тема:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" SelectedValue="{x:Bind ViewModel.Theme, Mode=TwoWay}" SelectedValuePath="Tag" HorizontalAlignment="Left" MinWidth="150">
                            <ComboBoxItem Content="Системная" Tag="Default" IsSelected="True"/>
                            <ComboBoxItem Content="Светлая" Tag="Light"/>
                            <ComboBoxItem Content="Тёмная" Tag="Dark"/>
                        </ComboBox>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Язык субтитров:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" SelectedValue="{x:Bind ViewModel.PreferredLanguage, Mode=TwoWay}" SelectedValuePath="Tag" HorizontalAlignment="Left" MinWidth="150">
                            <ComboBoxItem Content="Русский" Tag="ru" IsSelected="True"/>
                            <ComboBoxItem Content="English" Tag="en"/>
                            <ComboBoxItem Content="Українська" Tag="uk"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Expander>

            <!-- Updates -->
            <Expander>
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#x21BB;" FontSize="16"/>
                        <TextBlock Text="Обновления" Style="{StaticResource BodyTextBlockStyle}" FontWeight="SemiBold"/>
                    </StackPanel>
                </Expander.Header>
                <StackPanel Spacing="12" Padding="16">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Проверить обновления yt-dlp" Command="{x:Bind ViewModel.CheckUpdatesCommand}" CornerRadius="4" Padding="12,8"/>
                        <CheckBox Content="Автопроверка обновлений" IsChecked="{x:Bind ViewModel.AutoUpdate, Mode=TwoWay}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" Opacity="0.7" FontSize="12"/>
                </StackPanel>
            </Expander>

            <!-- Save -->
            <Button Content="Сохранить настройки"
                    Style="{StaticResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.SaveCommand}"
                    HorizontalAlignment="Center"
                    Padding="32,12"
                    CornerRadius="8"
                    FontSize="14"
                    Margin="0,8,0,16"/>
        </StackPanel>
    </ScrollViewer>
</Page>
