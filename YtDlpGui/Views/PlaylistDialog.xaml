<ContentDialog
    x:Class="YtDlpGui.Views.PlaylistDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Плейлист"
    PrimaryButtonText="Загрузить"
    CloseButtonText="Отмена"
    DefaultButton="Primary"
    CornerRadius="8"
    MinWidth="600"
    MinHeight="400">

    <StackPanel Spacing="16">
        <TextBlock x:Name="PlaylistTitle"
                   Style="{StaticResource SubtitleTextBlockStyle}"
                   TextWrapping="Wrap"/>

        <TextBlock x:Name="PlaylistInfo"
                   Opacity="0.7" FontSize="12"/>

        <RadioButtons x:Name="PlaylistModeGroup" Header="Режим выбора">
            <RadioButton Content="Весь плейлист" IsChecked="True" Tag="All"/>
            <RadioButton Content="Диапазон номеров" Tag="Range"/>
            <RadioButton Content="Выбор вручную" Tag="Manual"/>
        </RadioButtons>

        <Grid x:Name="RangePanel" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="60"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="С:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <NumberBox Grid.Column="1" x:Name="RangeStartBox" Minimum="1" Value="1"/>
            <TextBlock Grid.Column="2" Text="По:" VerticalAlignment="Center" Margin="8,0,8,0"/>
            <NumberBox Grid.Column="3" x:Name="RangeEndBox" Minimum="1"/>
        </Grid>

        <ListView x:Name="PlaylistItemsList"
                  MaxHeight="300"
                  SelectionMode="Extended"
                  x:DeferLoadStrategy="Lazy">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="4,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" IsChecked="True" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" Opacity="0.5" Width="30"/>
                        <TextBlock Grid.Column="2" Text="Title" MaxLines="1" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="3" Text="Duration" Opacity="0.5" HorizontalAlignment="Right"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <CheckBox x:Name="CreateDirCheckBox"
                  Content="Создать папку с именем плейлиста"
                  IsChecked="True"/>
        <CheckBox x:Name="NumberFilesCheckBox"
                  Content="Нумеровать файлы"
                  IsChecked="True"/>
    </StackPanel>
</ContentDialog>
