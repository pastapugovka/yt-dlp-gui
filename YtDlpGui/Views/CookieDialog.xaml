<ContentDialog
    x:Class="YtDlpGui.Views.CookieDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Импорт кук"
    PrimaryButtonText="Импортировать"
    CloseButtonText="Отмена"
    DefaultButton="Primary"
    CornerRadius="8"
    MinWidth="500">

    <StackPanel Spacing="16">
        <TextBlock Text="Выберите источник кук:" FontWeight="SemiBold"/>

        <RadioButton x:Name="FileRadio"
                     Content="Импорт из файла (Netscape/JSON)"
                     IsChecked="True"
                     GroupName="CookieSource"
                     Margin="0,0,0,8"/>

        <RadioButton x:Name="BrowserRadio"
                     Content="Импорт из браузера"
                     GroupName="CookieSource"
                     Margin="0,0,0,8"/>

        <RadioButton x:Name="ClipboardRadio"
                     Content="Вставить из буфера обмена"
                     GroupName="CookieSource"
                     Margin="0,0,0,16"/>

        <!-- Browser Selection -->
        <StackPanel x:Name="BrowserPanel"
                    Visibility="Collapsed"
                    Orientation="Horizontal"
                    Spacing="8">
            <TextBlock Text="Браузер:" VerticalAlignment="Center"/>
            <ComboBox x:Name="BrowserCombo"
                      MinWidth="150">
                <ComboBoxItem Content="Chrome" IsSelected="True"/>
                <ComboBoxItem Content="Edge"/>
                <ComboBoxItem Content="Firefox"/>
                <ComboBoxItem Content="Opera"/>
                <ComboBoxItem Content="Opera GX"/>
            </ComboBox>
        </StackPanel>

        <!-- Manual Input -->
        <StackPanel x:Name="ManualPanel"
                    Visibility="Collapsed"
                    Spacing="8">
            <TextBlock Text="Вставьте текст кук:" Opacity="0.8"/>
            <TextBox x:Name="CookieTextBox"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Height="150"
                     FontFamily="Cascadia Code, Consolas"
                     FontSize="12"
                     CornerRadius="4"
                     PlaceholderText="# Netscape HTTP Cookie File&#10;.youtube.com    TRUE    /    FALSE    0    CONSENT    YES+..."/>
        </StackPanel>

        <InfoBar x:Name="CookieInfoBar"
                 IsOpen="False"
                 IsClosable="True"
                 Severity="Informational"/>
    </StackPanel>
</ContentDialog>
