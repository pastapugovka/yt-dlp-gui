<Page
    x:Class="YtDlpGui.Views.ConsolePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:YtDlpGui.Views"
    xmlns:vm="using:YtDlpGui.ViewModels"
    xmlns:converters="using:YtDlpGui.Converters">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid Padding="16" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Встроенный терминал"
                       Style="{StaticResource TitleTextBlockStyle}"
                       VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Content="Очистить"
                        Command="{x:Bind ViewModel.ClearCommand}"
                        CornerRadius="4"
                        Padding="12,6"/>
                <Button x:Name="StopBtn"
                        Content="Остановить"
                        Command="{x:Bind ViewModel.StopCommand}"
                        CornerRadius="4"
                        Padding="12,6"
                        Visibility="{x:Bind ViewModel.IsRunning, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      x:Name="ConsoleScroller"
                      Background="#1E1E1E"
                      CornerRadius="8"
                      Padding="12">
            <RichTextBlock x:Name="ConsoleOutput"
                           FontFamily="Cascadia Code, Consolas"
                           FontSize="13"
                           Foreground="#CCCCCC"
                           TextWrapping="Wrap">
                <Run Text="{x:Bind ViewModel.ConsoleOutput, Mode=OneWay}"/>
            </RichTextBlock>
        </ScrollViewer>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="yt-dlp&gt;" Margin="0,0,8,0"
                       FontFamily="Cascadia Code, Consolas"
                       VerticalAlignment="Center"
                       Foreground="#4EC9B0"/>
            <TextBox Grid.Column="1"
                     x:Name="InputBox"
                     Text="{x:Bind ViewModel.InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     KeyDown="InputBox_KeyDown"
                     FontFamily="Cascadia Code, Consolas"
                     Background="#2D2D2D"
                     Foreground="#DCDCDC"
                     PlaceholderText="Введите команду..."
                     CornerRadius="4"/>
            <Button Grid.Column="2"
                    Content="Выполнить"
                    Command="{x:Bind ViewModel.ExecuteCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    CornerRadius="4"
                    Padding="16,8"
                    Margin="8,0,0,0"/>
        </Grid>
    </Grid>
</Page>
