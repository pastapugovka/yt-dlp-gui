<Page
    x:Class="YtDlpGui.Views.DownloadPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:YtDlpGui.Views"
    xmlns:vm="using:YtDlpGui.ViewModels"
    xmlns:converters="using:YtDlpGui.Converters">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- URL Input -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     x:Name="UrlTextBox"
                     PlaceholderText="Вставьте ссылку на видео..."
                     CornerRadius="4"
                     FontSize="14"
                     Padding="8"
                     Text="{x:Bind ViewModel.Url, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     KeyDown="UrlTextBox_KeyDown"/>
            <Button Grid.Column="1"
                    Content="&#x1F4CB;"
                    ToolTipService.ToolTip="Вставить из буфера обмена"
                    Margin="8,0,0,0"
                    Command="{x:Bind ViewModel.PasteFromClipboardCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    CornerRadius="4"
                    Padding="12,8"/>
            <Button Grid.Column="2"
                    Content="Анализировать"
                    Margin="8,0,0,0"
                    Command="{x:Bind ViewModel.AnalyzeCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    CornerRadius="4"
                    Padding="16,8"/>
            <Button Grid.Column="3"
                    Content="&#x1F36A;"
                    ToolTipService.ToolTip="Куки из буфера обмена"
                    Margin="8,0,0,0"
                    Command="{x:Bind ViewModel.PasteCookiesCommand}"
                    CornerRadius="4"
                    Padding="12,8"/>
            <Button Grid.Column="4"
                    Content="&#x1F4C2;"
                    ToolTipService.ToolTip="Открыть папку загрузок"
                    Margin="8,0,0,0"
                    Command="{x:Bind ViewModel.OpenOutputDirCommand}"
                    CornerRadius="4"
                    Padding="12,8"/>
        </Grid>

        <!-- Video Info Preview -->
        <Grid Grid.Row="1"
              x:Name="VideoInfoPanel"
              Visibility="{x:Bind ViewModel.HasVideoInfo, Converter={StaticResource BoolToVis}}"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              CornerRadius="8"
              Padding="16"
              Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0"
                   x:Name="ThumbnailImage"
                   MaxWidth="240"
                   MaxHeight="135"
                   CornerRadius="4"
                   Margin="0,0,16,0"
                   Stretch="UniformToFill">
                <Image.Source>
                    <BitmapImage UriSource="{x:Bind ViewModel.ThumbnailUrl, Mode=OneWay}"/>
                </Image.Source>
            </Image>

            <StackPanel Grid.Column="1" Spacing="6">
                <TextBlock Text="{x:Bind ViewModel.Title, Mode=OneWay}"
                           Style="{StaticResource TitleTextBlockStyle}"
                           MaxLines="2"
                           TextWrapping="Wrap"/>
                <TextBlock Text="{x:Bind ViewModel.Uploader, Mode=OneWay}"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           Opacity="0.7"/>
            </StackPanel>
        </Grid>

        <!-- Quality Selection -->
        <Grid Grid.Row="2" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,8,0" Spacing="4">
                <TextBlock Text="Видеокодек" Opacity="0.7" FontSize="12"/>
                <ComboBox x:Name="VideoCodecCombo"
                          ItemsSource="{x:Bind ViewModel.AvailableCodecs}"
                          SelectedValue="{x:Bind ViewModel.VideoCodec, Mode=TwoWay}"
                          HorizontalAlignment="Stretch"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Grid.Row="0" Margin="4,0,4,0" Spacing="4">
                <TextBlock Text="Разрешение" Opacity="0.7" FontSize="12"/>
                <ComboBox x:Name="ResolutionCombo"
                          ItemsSource="{x:Bind ViewModel.AvailableResolutions}"
                          SelectedValue="{x:Bind ViewModel.Resolution, Mode=TwoWay}"
                          HorizontalAlignment="Stretch"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Grid.Row="0" Margin="4,0,4,0" Spacing="4">
                <TextBlock Text="Аудиокодек" Opacity="0.7" FontSize="12"/>
                <ComboBox x:Name="AudioCodecCombo"
                          ItemsSource="{x:Bind ViewModel.AvailableAudioCodecs}"
                          SelectedValue="{x:Bind ViewModel.AudioCodec, Mode=TwoWay}"
                          HorizontalAlignment="Stretch"/>
            </StackPanel>

            <StackPanel Grid.Column="3" Grid.Row="0" Margin="8,0,0,0" Spacing="4">
                <TextBlock Text="Битрейт" Opacity="0.7" FontSize="12"/>
                <ComboBox x:Name="BitrateCombo"
                          ItemsSource="{x:Bind ViewModel.AvailableBitrates}"
                          SelectedValue="{x:Bind ViewModel.AudioBitrate, Mode=TwoWay}"
                          HorizontalAlignment="Stretch"/>
            </StackPanel>

            <StackPanel Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0,8,0,0" Spacing="16">
                <CheckBox Content="Только аудио"
                          IsChecked="{x:Bind ViewModel.AudioOnly, Mode=TwoWay}"
                          VerticalAlignment="Center"/>
                <CheckBox Content="Только видео"
                          IsChecked="{x:Bind ViewModel.VideoOnly, Mode=TwoWay}"
                          VerticalAlignment="Center"/>
                <CheckBox Content="Аудио отдельным файлом"
                          IsChecked="{x:Bind ViewModel.SeparateAudio, Mode=TwoWay}"
                          VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- File Name Template -->
        <Grid Grid.Row="3" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Шаблон имени:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox Grid.Column="1"
                     x:Name="FileNameTemplateBox"
                     Text="{x:Bind ViewModel.FileNameTemplate, Mode=TwoWay}"
                     CornerRadius="4"/>
            <Button Grid.Column="2"
                    Content="..."
                    Margin="8,0,0,0"
                    ToolTipService.ToolTip="Расширенные флаги"
                    Click="ShowAdvancedFlags_Click"
                    CornerRadius="4"
                    Padding="12,8"/>
        </Grid>

        <!-- Advanced Flags (collapsible) -->
        <Grid Grid.Row="4"
              x:Name="AdvancedFlagsPanel"
              Visibility="Collapsed"
              Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Доп. флаги:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox Grid.Column="1"
                     x:Name="AdvancedFlagsBox"
                     Text="{x:Bind ViewModel.AdvancedFlags, Mode=TwoWay}"
                     CornerRadius="4"
                     PlaceholderText="--no-check-certificate --force-ipv4 ..."/>
        </Grid>

        <!-- Progress -->
        <Grid Grid.Row="5" Margin="0,4,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                               Opacity="0.8"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="{x:Bind ViewModel.CurrentFileText, Mode=OneWay}"
                               Opacity="0.5"
                               FontSize="12"
                               MaxWidth="400"
                               TextTrimming="CharacterEllipsis"
                               HorizontalAlignment="Right"/>
                </Grid>
                <ProgressBar x:Name="DownloadProgress"
                             Value="{x:Bind ViewModel.ProgressValue, Mode=OneWay}"
                             Maximum="100"
                             Height="8"
                             CornerRadius="4"
                             Opacity="0.9"/>
            </StackPanel>

            <!-- Log Output -->
            <ScrollViewer Grid.Row="1"
                          x:Name="LogScroller"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                          CornerRadius="8"
                          Padding="8">
                <RichTextBlock x:Name="LogRichText"
                               FontFamily="Cascadia Code, Consolas"
                               FontSize="12"
                               TextWrapping="Wrap">
                    <Run Text="{x:Bind ViewModel.LogText, Mode=OneWay}"/>
                </RichTextBlock>
            </ScrollViewer>
        </Grid>

        <!-- Download Button -->
        <Grid Grid.Row="6" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                <Button x:Name="DownloadBtn"
                        Content="СКАЧАТЬ"
                        Style="{StaticResource AccentButtonStyle}"
                        FontSize="16"
                        FontWeight="Bold"
                        Padding="32,12"
                        CornerRadius="8"
                        HorizontalAlignment="Left"
                        Command="{x:Bind ViewModel.DownloadCommand}"/>
                <Button x:Name="CancelBtn"
                        Content="Остановить"
                        Padding="16,12"
                        CornerRadius="8"
                        HorizontalAlignment="Left"
                        Command="{x:Bind ViewModel.CancelCommand}"
                        Visibility="{x:Bind ViewModel.IsDownloading, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>

            <Button Grid.Column="2"
                    Content="Очистить лог"
                    Padding="16,12"
                    CornerRadius="8"
                    Command="{x:Bind ViewModel.ClearLogCommand}"
                    HorizontalAlignment="Right"/>
        </Grid>
    </Grid>
</Page>
